{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "credential_id",
    "rp_id",
    "origin",
    "user_handle",
    "user_name",
    "cose_alg",
    "public_key_cose",
    "private_key_pkcs8",
    "aaguid",
    "backup_eligible",
    "backup_state",
    "sign_count",
    "transports"
  ],
  "properties": {
    "object_type": {
      "const": "PASSLY_PASSKEY"
    },
    "schema_version": {
      "const": 1
    },
    "credential_id": {
      "type": "string",
      "maxLength": 2048
    },
    "rp_id": {
      "type": "string",
      "maxLength": 255
    },
    "origin": {
      "type": "string",
      "maxLength": 2048
    },
    "user_handle": {
      "type": "string",
      "maxLength": 2048
    },
    "user_name": {
      "type": "string",
      "maxLength": 255
    },
    "user_display_name": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 255
        },
        {
          "type": "null"
        }
      ]
    },
    "cose_alg": {
      "type": "integer"
    },
    "public_key_cose": {
      "type": "string",
      "maxLength": 16384
    },
    "private_key_pkcs8": {
      "type": "string",
      "maxLength": 16384
    },
    "aaguid": {
      "type": "string",
      "format": "uuid"
    },
    "backup_eligible": {
      "type": "boolean"
    },
    "backup_state": {
      "type": "boolean"
    },
    "sign_count": {
      "type": "integer",
      "minimum": 0
    },
    "transports": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ble",
          "cable",
          "hybrid",
          "internal",
          "nfc",
          "smart-card",
          "usb"
        ]
      },
      "maxItems": 16
    }
  }
}
